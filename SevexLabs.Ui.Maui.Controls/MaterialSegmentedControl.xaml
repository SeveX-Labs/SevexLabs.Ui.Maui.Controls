<?xml version="1.0" encoding="utf-8"?>
<controls:FastBorder xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                     xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                     xmlns:controls="clr-namespace:SevexLabs.Ui.Maui.Controls"
                     x:Class="SevexLabs.Ui.Maui.Controls.MaterialSegmentedControl"
                     x:Name="Self"
                     HorizontalOptions="Fill">
    
    <FlexLayout x:Name="FlexContainer" Wrap="NoWrap" Direction="Row" JustifyContent="Start" AlignItems="Stretch"
                HorizontalOptions="Fill" VerticalOptions="Fill"
                BindableLayout.ItemsSource="{Binding Source={x:Reference Self}, Path=Items}">
        
        <BindableLayout.ItemTemplate>
            <DataTemplate x:DataType="controls:Segment">
                <controls:MaterialSegment SegmentText="{Binding Label}"
                                          IsSelected="{Binding IsSelected}"
                                          Style="{Binding Source={x:Reference Self}, Path=SegmentStyle}"
                                          VerticalOptions="Fill" HorizontalOptions="Fill"
                                          FlexLayout.AlignSelf="Stretch"
                                          FlexLayout.Basis="0"
                                          FlexLayout.Grow="1"
                                          FlexLayout.Shrink="1">
                    
                    <VisualElement.Triggers>
                        <!-- Equal -->
                        <DataTrigger TargetType="controls:MaterialSegment"
                                     Binding="{Binding Source={x:Reference Self}, Path=SegmentsWidthMode}"
                                     Value="Equal">
                            <Setter Property="FlexLayout.Basis"  Value="0" />
                            <Setter Property="FlexLayout.Grow"   Value="1" />
                            <Setter Property="FlexLayout.Shrink" Value="1" />
                        </DataTrigger>

                        <!-- Auto -->
                        <DataTrigger TargetType="controls:MaterialSegment"
                                     Binding="{Binding Source={x:Reference Self}, Path=SegmentsWidthMode}"
                                     Value="Auto">
                            <Setter Property="FlexLayout.Basis"  Value="Auto" />
                            <Setter Property="FlexLayout.Grow"   Value="0" />
                            <Setter Property="FlexLayout.Shrink" Value="0" />
                        </DataTrigger>
                    </VisualElement.Triggers>
                    
                    <controls:MaterialSegment.GestureRecognizers>
                        <TapGestureRecognizer Tapped="HandleSegmentTappedInternal" 
                                              CommandParameter="{Binding .}"></TapGestureRecognizer>
                    </controls:MaterialSegment.GestureRecognizers>
                </controls:MaterialSegment>
            </DataTemplate>
        </BindableLayout.ItemTemplate>
        
    </FlexLayout>
</controls:FastBorder>