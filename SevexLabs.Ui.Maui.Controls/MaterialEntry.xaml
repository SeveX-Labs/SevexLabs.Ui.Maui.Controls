<?xml version="1.0" encoding="utf-8" ?>
<controls:FastBorder
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:SevexLabs.Ui.Maui.Controls"
    x:Class="SevexLabs.Ui.Maui.Controls.MaterialEntry"
    x:Name="this">

    <Grid x:Name="RootGrid"
          HorizontalOptions="Fill"
          VerticalOptions="Fill">

        <!-- TAP CATCHER: cattura tap ovunque e forza focus -->
        <BoxView x:Name="TapCatcher"
                 BackgroundColor="Transparent"
                 HorizontalOptions="Fill"
                 VerticalOptions="Fill"
                 InputTransparent="False">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnTapCatcherTapped" />
            </BoxView.GestureRecognizers>
        </BoxView>

        <!-- Floating placeholder -->
        <Label x:Name="FloatingPlaceholderLabel"
               TextColor="LightGray"
               InputTransparent="True"
               VerticalOptions="Center"
               HorizontalOptions="Start"
               TranslationY="0"
               Scale="1"
               IsVisible="False" />

        <!-- Entry -->
        <controls:BorderlessEntry x:Name="InnerEntry"
                                  PlaceholderColor="LightGray"
                                  TextColor="Black"
                                  BackgroundColor="Transparent"
                                  HorizontalOptions="Fill"
                                  VerticalOptions="Center"
                                  TextChanged="OnInnerEntryTextChanged"
                                  Focused="OnInnerEntryFocused"
                                  Unfocused="OnInnerEntryUnfocused" />

        <!-- Eye container: width auto (Image + Padding), height fill -->
        <Grid x:Name="EyeContainer"
              IsVisible="False"
              HorizontalOptions="End"
              VerticalOptions="Fill"
              BackgroundColor="Transparent">

            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnEyeTapped" />
            </Grid.GestureRecognizers>

            <Image x:Name="EyeImage"
                   WidthRequest="24"
                   HeightRequest="24"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
        </Grid>

        <!-- ReadOnly tap area -->
        <BoxView x:Name="ReadOnlyTapArea"
                 HorizontalOptions="Fill"
                 VerticalOptions="Fill"
                 BackgroundColor="Transparent"
                 IsVisible="False">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnReadOnlyTapped" />
            </BoxView.GestureRecognizers>
        </BoxView>

    </Grid>
</controls:FastBorder>
