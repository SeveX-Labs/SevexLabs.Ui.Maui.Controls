<?xml version="1.0" encoding="utf-8" ?>
<controls:FastBorder
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:SevexLabs.Ui.Maui.Controls"
    x:Class="SevexLabs.Ui.Maui.Controls.MaterialDisplayField"
    x:Name="this">

    <Grid x:Name="RootGrid"
          HorizontalOptions="Fill"
          VerticalOptions="Fill">

        <!-- TAP CATCHER: cattura tap ovunque -->
        <BoxView x:Name="TapCatcher"
                 BackgroundColor="Transparent"
                 HorizontalOptions="Fill"
                 VerticalOptions="Fill"
                 InputTransparent="False">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnTapCatcherTapped" />
            </BoxView.GestureRecognizers>
        </BoxView>

        <!-- Floating placeholder -->
        <Label x:Name="FloatingPlaceholderLabel"
               InputTransparent="True"
               VerticalOptions="Center"
               HorizontalOptions="Start"
               TextColor="LightGray"
               TranslationY="0"
               Scale="1"
               IsVisible="False" />

        <!-- Value (read-only) -->
        <Label x:Name="ValueLabel"
               InputTransparent="True"
               VerticalOptions="Center"
               HorizontalOptions="Fill"
               HorizontalTextAlignment="Start"
               LineBreakMode="TailTruncation"
               TextColor="Black"
               TranslationY="0" />

    </Grid>
</controls:FastBorder>
